@baseUrl = http://localhost:3001

### Health del servicio orquestador de pedidos
GET {{baseUrl}}/health

### 1. CP-01 Registro correcto de pedido
# Resultado esperado: pedidos llama a inventario, facturacion, transporte y notificaciones.
POST {{baseUrl}}/pedidos
Content-Type: application/json

{
  "cliente": "Supermercado Sur",
  "tipoCliente": "Normal",
  "productoId": "P001",
  "cantidad": 10
}

### 2. CP-02 Pedido con inventario insuficiente
POST {{baseUrl}}/pedidos
Content-Type: application/json

{
  "cliente": "Supermercado Norte",
  "tipoCliente": "Normal",
  "productoId": "P002",
  "cantidad": 100
}

### 3. CP-03 Pedido con cantidad cero
POST {{baseUrl}}/pedidos
Content-Type: application/json

{
  "cliente": "Supermercado Centro",
  "tipoCliente": "Normal",
  "productoId": "P001",
  "cantidad": 0
}

### 4. CP-04 Pedido con cantidad negativa
POST {{baseUrl}}/pedidos
Content-Type: application/json

{
  "cliente": "Supermercado Centro",
  "tipoCliente": "Normal",
  "productoId": "P001",
  "cantidad": -5
}

